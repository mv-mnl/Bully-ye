{
    "layer": "top",
    "position": "top",
    "height": 40,
    "margin-top": 8,
    "margin-left": 10,
    "margin-right": 10,
    "spacing": 10,
    "modules-center": [
        "custom/nvim",
        "clock",
        "battery"
    ],
    "modules-left": [
        "image#album-art",
        "custom/spotify"
    ],
    "modules-right": [
        "hyprland/window",
        "custom/volume",
        "custom/button",
        "custom/waypaper",
        "network",
        "custom/notification-daemon"
    ],

    "hyprland/window": {
        "format": " ",
        "icon": true,
        "icon-size": 22,
        "tooltip": true,
        "tooltip-format": "{title}"
    },

    "custom/nvim": {
        "format": "’ē® ",
        "tooltip": false,
        "on-click": "kitty nvim"
    },


    "clock": {
        "format": "’ĆŚ  {:%H:%M}",
        "format-alt": "’ü│  {:%A, %B %d, %Y}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode"          : "year",
            "mode-mon-col"  : 3,
            "weeks-pos"     : "right",
            "on-scroll"     : 1,
            "format": {
                "months":     "<span color='#ffead3'><b>{}</b></span>",
                "days":       "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        }
    },
    "custom/notification-daemon": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
            "notification": "’éó<span foreground='red'><sup>’æä</sup></span>",
            "none": "’ā│",
            "dnd-notification": "’ćĘ<span foreground='red'><sup>’æä</sup></span>",
            "dnd-none": "’ćĘ",
            "inhibited-notification": "’éó<span foreground='red'><sup>’æä</sup></span>",
            "inhibited-none": "’ā│",
            "dnd-inhibited-notification": "’ćĘ<span foreground='red'><sup>’æä</sup></span>",
            "dnd-inhibited-none": "’ćĘ"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "’ć”  {capacity}%",
        "format-plugged": "’ć”  {capacity}%",
        "format-alt": "{icon}  {time}",
        "format-icons": ["’ēä", "’ēā", "’ēé", "’ēü", "’ēĆ"]
    },
    "network": {
        "format-wifi": "’ć½   {essid}",
        "format-ethernet": "¾░łĆ   {ipaddr}",
        "tooltip-format": "{ifname} via {gwaddr} ¾░łĆ",
        "format-linked": "{ifname} (No IP) ¾░łĆ",
        "format-disconnected": "ŌÜĀ  Disconnected",
        "on-click": "networkmanager_dmenu"
    },
    "image#album-art": {
        "exec": "if [ -f /tmp/waybar-cover.jpeg ]; then echo /tmp/waybar-cover.jpeg; else echo ''; fi",
        "size": 32,
        "interval": 2,
        "on-click": "eww open media_menu --toggle"
    },
    "custom/spotify": {
        "format": "{}",
        "exec": "/home/manuelmv/Bully-ye/waybar/scrips.sh",
        "return-type": "json",
        "interval": 1,
        "on-click": "eww open media_menu --toggle",
        "tooltip": false
    },
    "custom/volume": {
        "format": "’Ć©   {}%",
        "tooltip": false,
        "on-click": "/home/manuelmv/Bully-ye/eww/scripts/volume-manager.sh toggle",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-",
        "exec": "wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{print int($2 * 100)}'",
        "interval": 1
    },
    "custom/button": {
        "format": "’ł│ ",
        "tooltip": true,
        "tooltip-format": "Lanzar Bottom (btm)",
        "on-click": "kitty btm"
    },
    "custom/waypaper": {
        "format": "’ĆŠ ",
        "tooltip": true,
        "tooltip-format": "Cambiar Fondo (Waypaper)",
        "on-click": "~/Bully-ye/wallpaper-carousel/run-carousel.sh"
    },
    "custom/darkmode": {
        "format": "{icon}",
        "return-type": "json",
        "exec": "/home/manuelmv/Bully-ye/waybar/darkmode-status.sh",
        "interval": "once",
        "signal": 8,
        "format-icons": {
            "dark": "¾░¢ā",
            "light": "¾░¢ö"
        },
        "tooltip": true,
        "tooltip-format": "Cambiar modo d├Ła/noche",
        "on-click": "/home/manuelmv/Bully-ye/waybar/darkmode-toggle.sh"
    }
}

